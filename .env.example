# Pusher Channels — free tier is fine for a classroom presentation.
# Sign up at https://pusher.com/channels, create a "Channels" app,
# then paste the values below.

# Client-side (exposed to the browser)
NEXT_PUBLIC_PUSHER_KEY=your_app_key_here
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# Server-side (never exposed to the client)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=same_as_NEXT_PUBLIC_PUSHER_KEY
PUSHER_SECRET=your_app_secret

# Presentation token signing secret (server-side only)
# Generate a long random string; used to sign the stage and presenter session tokens.
PRESENTATION_TOKEN_SECRET=replace_with_a_long_random_secret
